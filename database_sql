- SQL structures
- 2 tables
- 5 indexes
- 1 foreign key
- JSONB snapshot storage
- UUID primary keys
- audit logging relationship

- github_analysis

CREATE TABLE github_analysis (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    github_username VARCHAR(255) NOT NULL,

    repo_snapshot JSONB NOT NULL,

    analysis TEXT NOT NULL,

    model_name VARCHAR(100) NOT NULL,

    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);


- analysis_request_log

CREATE TABLE analysis_request_log (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),

    github_username VARCHAR(255) NOT NULL,

    analysis_id UUID NULL,

    success BOOLEAN NOT NULL DEFAULT TRUE,

    duration_ms INTEGER NOT NULL,

    error_message TEXT NULL,

    requested_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    CONSTRAINT fk_analysis
        FOREIGN KEY (analysis_id)
        REFERENCES github_analysis(id)
        ON DELETE SET NULL
);